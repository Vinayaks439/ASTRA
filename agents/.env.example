# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-primary-key
COSMOS_DATABASE=voltedge-pricing-db

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=astra-gpt
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure Service Bus
SERVICEBUS_CONNECTION=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...

# Agent URLs (local dev defaults)
RISK_AGENT_URL=http://localhost:7071
RECOMMENDATION_AGENT_URL=http://localhost:7072
TRIAGE_AGENT_URL=http://localhost:7073
RATIONALE_AGENT_URL=http://localhost:7074
INSIGHTS_AGENT_URL=http://localhost:7075
NOTIFICATION_AGENT_URL=http://localhost:7076
